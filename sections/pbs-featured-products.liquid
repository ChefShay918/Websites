{%- liquid
  assign products_to_show = section.settings.products_to_show
  if section.settings.collection != blank
    assign featured_collection = collections[section.settings.collection]
  endif
-%}

<section class="pbs-featured-products section">
  <div class="container">
    {%- if section.settings.heading != blank -%}
      <h2 class="section__heading">{{ section.settings.heading | escape }}</h2>
    {%- endif -%}

    {%- if featured_collection != blank and featured_collection.products_count > 0 -%}
      <div class="product-grid">
        {%- for product in featured_collection.products limit: products_to_show -%}
          {%- render 'product-card', product: product -%}
        {%- endfor -%}
      </div>
    {%- else -%}
      <div class="product-grid">
        {%- for i in (1..products_to_show) -%}
          <div class="product-card">
            <div class="product-card__image-link">
              <div class="product-card__image product-card__image--placeholder">
                {{ 'product-' | append: i | placeholder_svg_tag: 'placeholder-svg' }}
              </div>
            </div>
            <div class="product-card__info">
              <h3 class="product-card__title">
                <a href="#">{{ 'onboarding.product_title' | t }}</a>
              </h3>
              <p class="product-card__price">
                <span class="product-card__price--current">$28.00</span>
              </p>
              <a href="#" class="btn btn--primary product-card__btn">
                {{ 'products.product.instant_download' | t }}
              </a>
            </div>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Featured Products",
  "tag": "div",
  "class": "featured-products-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "Shop Our Favs"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Products to show",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 4
    }
  ],
  "presets": [
    {
      "name": "Featured Products",
      "settings": {
        "heading": "Shop Our Favs",
        "products_to_show": 4
      }
    }
  ]
}
{% endschema %}
