<footer class="site-footer" role="contentinfo">
  <div class="container">
    <div class="site-footer__grid">

      <!-- Brand column -->
      <div class="site-footer__logo-col">
        <a href="{{ routes.root_url }}" aria-label="{{ shop.name }}">
          <img
            src="{{ 'logo-dark.svg' | asset_url }}"
            alt="{{ shop.name }}"
            width="160"
            height="auto"
            loading="lazy"
          >
        </a>
        <p class="site-footer__tagline">
          {{ 'sections.footer.tagline' | t }}
        </p>
      </div>

      <!-- Quick links -->
      <nav class="site-footer__col" aria-label="{{ 'sections.footer.quick_links' | t }}">
        <p class="site-footer__col-heading">{{ 'sections.footer.quick_links' | t }}</p>
        <ul class="site-footer__links">
          <li><a class="site-footer__link" href="{{ routes.collections_url }}">{{ 'sections.footer.link_shop' | t }}</a></li>
          <li><a class="site-footer__link" href="{{ routes.collections_url }}">{{ 'sections.footer.link_collections' | t }}</a></li>
          <li><a class="site-footer__link" href="{{ routes.root_url }}pages/contact">{{ 'sections.footer.link_contact' | t }}</a></li>
          <li><a class="site-footer__link" href="{{ routes.root_url }}pages/faq">{{ 'sections.footer.link_faq' | t }}</a></li>
        </ul>
      </nav>

      <!-- Social -->
      <div class="site-footer__col">
        <p class="site-footer__col-heading">{{ 'sections.footer.follow_us' | t }}</p>
        <div class="site-footer__social-icons">
          {%- if section.settings.instagram_url != blank -%}
            <a class="social-icon" href="{{ section.settings.instagram_url }}" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
                <circle cx="12" cy="12" r="4"/>
                <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/>
              </svg>
            </a>
          {%- endif -%}
          {%- if section.settings.facebook_url != blank -%}
            <a class="social-icon" href="{{ section.settings.facebook_url }}" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
              </svg>
            </a>
          {%- endif -%}
          {%- if section.settings.tiktok_url != blank -%}
            <a class="social-icon" href="{{ section.settings.tiktok_url }}" target="_blank" rel="noopener noreferrer" aria-label="TikTok">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.18 8.18 0 0 0 4.78 1.52V6.77a4.85 4.85 0 0 1-1.01-.08z"/>
              </svg>
            </a>
          {%- endif -%}
        </div>
      </div>

    </div>

    <div class="site-footer__bottom">
      <p class="site-footer__copyright">
        &copy; {{ 'now' | date: '%Y' }} {{ shop.name }} &middot; {{ 'sections.footer.powered_by' | t }}
      </p>
      <div class="site-footer__payment-icons" aria-label="{{ 'sections.footer.payment_methods' | t }}">
        {%- for type in shop.enabled_payment_types -%}
          {{ type | payment_type_svg_tag: class: 'payment-icon' }}
        {%- endfor -%}
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "tag": "div",
  "class": "footer-wrapper",
  "limit": 1,
  "settings": [
    {
      "type": "header",
      "content": "Social links"
    },
    {
      "type": "url",
      "id": "instagram_url",
      "label": "Instagram URL"
    },
    {
      "type": "url",
      "id": "facebook_url",
      "label": "Facebook URL"
    },
    {
      "type": "url",
      "id": "tiktok_url",
      "label": "TikTok URL"
    }
  ]
}
{% endschema %}
