<header class="site-header" role="banner">
  <div class="container site-header__inner">

    <a class="site-header__logo" href="{{ routes.root_url }}" aria-label="{{ shop.name }}">
      <img
        src="{{ 'logo-light.svg' | asset_url }}"
        alt="{{ shop.name }}"
        width="{{ section.settings.logo_width }}"
        height="auto"
        loading="eager"
      >
    </a>

    <nav class="site-nav" aria-label="{{ 'sections.header.navigation_label' | t }}">
      <a class="site-nav__link" href="{{ routes.collections_url }}">{{ 'sections.header.nav.shop' | t }}</a>
      <a class="site-nav__link" href="{{ routes.collections_url }}">{{ 'sections.header.nav.collections' | t }}</a>
      <a class="site-nav__link" href="{{ routes.root_url }}pages/about">{{ 'sections.header.nav.about' | t }}</a>
      <a class="site-nav__link" href="{{ routes.root_url }}pages/contact">{{ 'sections.header.nav.contact' | t }}</a>
    </nav>

    <div class="site-header__icons">
      <button class="header-icon-btn" aria-label="{{ 'general.search.search' | t }}" onclick="document.querySelector('.search-drawer')?.classList.toggle('is-open')">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="11" cy="11" r="7"/>
          <line x1="16.5" y1="16.5" x2="22" y2="22"/>
        </svg>
      </button>

      <a class="header-icon-btn" href="{{ routes.cart_url }}" aria-label="{{ 'sections.header.cart_label' | t: count: cart.item_count }}">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
          <line x1="3" y1="6" x2="21" y2="6"/>
          <path d="M16 10a4 4 0 0 1-8 0"/>
        </svg>
        {%- if cart.item_count > 0 -%}
          <span class="cart-count" aria-hidden="true">{{ cart.item_count }}</span>
        {%- endif -%}
      </a>
    </div>

  </div>
</header>

<style>
  .site-header.is-scrolled {
    box-shadow: 0 2px 16px rgba(44, 36, 22, 0.08);
  }
</style>

{% schema %}
{
  "name": "Header",
  "tag": "div",
  "class": "header-wrapper",
  "limit": 1,
  "settings": [
    {
      "type": "range",
      "id": "logo_width",
      "label": "Logo width (px)",
      "min": 100,
      "max": 300,
      "step": 10,
      "default": 180
    }
  ]
}
{% endschema %}
