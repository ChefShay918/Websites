<div class="announcement-bar" role="region" aria-label="{{ 'sections.announcement_bar.label' | t }}">
  <p class="announcement-bar__text">{{ section.settings.announcement_text }}</p>
</div>

{% schema %}
{
  "name": "Announcement Bar",
  "tag": "div",
  "class": "announcement-bar-wrapper",
  "limit": 1,
  "settings": [
    {
      "type": "text",
      "id": "announcement_text",
      "label": "Announcement text",
      "default": "Handmade with love · Free shipping on orders over $50"
    }
  ]
}
{% endschema %}
