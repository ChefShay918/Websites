<section class="pbs-hero section" aria-label="{{ 'sections.hero.label' | t }}">
  {%- if section.settings.image != blank -%}
    {{ section.settings.image | image_url: width: 2000 | image_tag:
      class: 'pbs-hero__bg-image',
      loading: 'eager',
      fetchpriority: 'high',
      alt: section.settings.image.alt | default: shop.name,
      widths: '750, 1100, 1500, 2000',
      sizes: '100vw'
    }}
  {%- endif -%}

  <div
    class="pbs-hero__overlay"
    style="opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};"
    aria-hidden="true"
  ></div>

  <div class="container pbs-hero__content">
    {%- if section.settings.heading != blank -%}
      <h1 class="pbs-hero__heading">{{ section.settings.heading | escape }}</h1>
    {%- endif -%}
    {%- if section.settings.subheading != blank -%}
      <p class="pbs-hero__subheading">{{ section.settings.subheading | escape }}</p>
    {%- endif -%}
    {%- if section.settings.cta_label != blank -%}
      <a
        class="btn btn--light"
        href="{{ section.settings.cta_url | default: routes.collections_url }}"
      >
        {{- section.settings.cta_label | escape -}}
      </a>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "tag": "div",
  "class": "hero-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Wear Something That Means Something"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Instant digital downloads — buy, download, create."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button URL"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Image overlay opacity",
      "min": 0,
      "max": 80,
      "step": 5,
      "default": 40,
      "unit": "%"
    }
  ],
  "presets": [
    {
      "name": "Hero",
      "settings": {
        "heading": "Wear Something That Means Something",
        "subheading": "Every shirt printed by hand, made for you.",
        "cta_label": "Shop Now"
      }
    }
  ]
}
{% endschema %}
