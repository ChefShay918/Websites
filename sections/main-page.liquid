<div class="container">
  <article class="page-content">
    <h1 class="page-content__title">{{ page.title }}</h1>
    {%- if page.content != blank -%}
      <div class="rte">{{ page.content }}</div>
    {%- endif -%}
  </article>
</div>

{% schema %}
{
  "name": "Page",
  "tag": "div",
  "class": "page-wrapper"
}
{% endschema %}
