<section class="pbs-about section">
  <div class="container">
    <div class="pbs-about__inner">
      <div class="pbs-about__content">
        {%- if section.settings.heading != blank -%}
          <h2 class="pbs-about__heading">{{ section.settings.heading | escape }}</h2>
        {%- endif -%}

        {%- if section.settings.body != blank -%}
          <div class="pbs-about__body rte">{{ section.settings.body }}</div>
        {%- endif -%}

        {%- if section.settings.cta_label != blank and section.settings.cta_url != blank -%}
          <div>
            <a class="btn btn--secondary" href="{{ section.settings.cta_url }}">
              {{- section.settings.cta_label | escape -}}
            </a>
          </div>
        {%- endif -%}
      </div>

      {%- if section.settings.image != blank -%}
        <div class="pbs-about__image">
          {{ section.settings.image | image_url: width: 900 | image_tag:
            loading: 'lazy',
            alt: section.settings.image.alt | default: shop.name,
            widths: '400, 600, 800, 900',
            sizes: '(min-width: 768px) 45vw, 90vw'
          }}
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "About Blurb",
  "tag": "div",
  "class": "about-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Made by Hand. Shipped with Love."
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Body text",
      "default": "<p>We're a small print shop where every design starts with an idea and ends with a shirt you'll actually want to wear. No factories, no middlemen — just us, some ink, and a whole lot of love.</p><p>Founded by Shay, PrintsByShay is built on the belief that what you wear should mean something.</p>"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "Learn More"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button URL"
    }
  ],
  "presets": [
    {
      "name": "About Blurb",
      "settings": {
        "heading": "Made by Hand. Shipped with Love.",
        "cta_label": "Learn More"
      }
    }
  ]
}
{% endschema %}
