<div class="container">
  <div class="product-layout">

    <!-- Media -->
    <div class="product-media">
      <div class="product-media__main">
        {%- if product.featured_image -%}
          {{ product.featured_image | image_url: width: 1000 | image_tag:
            loading: 'eager',
            fetchpriority: 'high',
            alt: product.featured_image.alt | default: product.title,
            widths: '500, 750, 1000',
            sizes: '(min-width: 768px) 45vw, 90vw',
            id: 'product-main-image'
          }}
        {%- else -%}
          {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
        {%- endif -%}
      </div>

      {%- if product.images.size > 1 -%}
        <div class="product-thumbnails">
          {%- for image in product.images limit: 8 -%}
            <button
              class="product-thumbnail{% if forloop.first %} is-active{% endif %}"
              data-src="{{ image | image_url: width: 1000 }}"
              aria-label="{{ image.alt | default: product.title | escape }} {{ forloop.index }}"
            >
              {{ image | image_url: width: 144 | image_tag:
                loading: 'lazy',
                alt: image.alt | default: product.title,
                widths: '72, 144',
                sizes: '72px'
              }}
            </button>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>

    <!-- Product form -->
    <div class="product-form">
      <span class="product-card__badge product-card__badge--download" style="position:static; display:inline-block; margin-bottom:0.75rem;">
        {{ 'products.product.instant_download' | t }}
      </span>

      <h1 class="product-form__title">{{ product.title }}</h1>

      <p class="product-form__price">
        {%- if product.compare_at_price > product.price -%}
          <s>{{ product.compare_at_price | money }}</s>
        {%- endif -%}
        {{ product.price | money }}
      </p>

      {%- form 'product', product, id: 'product-form' -%}
        <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">

        <button
          class="btn btn--primary product-form__add-to-cart"
          type="submit"
          name="add"
          {%- unless product.selected_or_first_available_variant.available -%}disabled{%- endunless -%}
        >
          {%- if product.selected_or_first_available_variant.available -%}
            {{ 'products.product.add_to_cart' | t }}
          {%- else -%}
            {{ 'products.product.sold_out' | t }}
          {%- endif -%}
        </button>
      {%- endform -%}

      <!-- What's Included -->
      <div class="product-whats-included">
        <h2 class="product-whats-included__heading">{{ 'products.product.whats_included_heading' | t }}</h2>
        <ul class="product-whats-included__list">
          <li class="product-whats-included__item">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-secondary)" stroke-width="2" stroke-linecap="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            {{ 'products.product.whats_included_png' | t }}
          </li>
          <li class="product-whats-included__item">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-secondary)" stroke-width="2" stroke-linecap="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            {{ 'products.product.whats_included_svg' | t }}
          </li>
          <li class="product-whats-included__item">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-secondary)" stroke-width="2" stroke-linecap="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            {{ 'products.product.whats_included_pdf' | t }}
          </li>
          <li class="product-whats-included__item">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-secondary)" stroke-width="2" stroke-linecap="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            {{ 'products.product.whats_included_usage' | t }}
          </li>
        </ul>
        <p class="product-whats-included__note">{{ 'products.product.digital_delivery_note' | t }}</p>
      </div>

      {%- if product.description != blank -%}
        <div class="product-form__description rte">
          {{ product.description }}
        </div>
      {%- endif -%}
    </div>

  </div>
</div>

<style>
  .product-whats-included {
    border: 1px solid var(--color-sand);
    border-radius: var(--border-radius);
    padding: var(--spacing-sm);
    background-color: var(--color-white);
    margin-top: var(--spacing-sm);
  }
  .product-whats-included__heading {
    font-family: var(--font-subheading);
    font-size: 0.9375rem;
    font-weight: 600;
    margin-bottom: 0.625rem;
  }
  .product-whats-included__list {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }
  .product-whats-included__item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9375rem;
  }
  .product-whats-included__note {
    margin-top: 0.75rem;
    font-size: 0.8125rem;
    color: var(--color-secondary);
    font-weight: 500;
  }
  .product-card__file-types {
    color: var(--color-secondary);
    font-size: 0.7rem;
  }
</style>

{% schema %}
{
  "name": "Product",
  "tag": "div",
  "class": "product-wrapper"
}
{% endschema %}
